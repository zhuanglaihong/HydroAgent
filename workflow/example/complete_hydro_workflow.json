        "param_range_file": "D:\\MCP\\hydromodel\\hydromodel\\models\\param.yaml",
        "algorithm": {
          "name": "SCE_UA",
          "random_seed": 1234,
          "rep": 50,
          "ngs": 15,
          "kstop": 3,
          "peps": 0.1,
          "pcento": 0.1
        },
        "loss": {
          "type": "time_series",
          "obj_func": "RMSE",
          "events": null
        }
      },
      "dependencies": ["task_prepare"],
      "conditions": {
        "retry_count": 1,
        "timeout": 1800
