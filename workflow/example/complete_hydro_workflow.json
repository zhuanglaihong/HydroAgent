      },
      "dependencies": [],
      "conditions": {
        "retry_count": 2,
        "timeout": 300
      },
      "expected_output": "处理后的数据文件路径和统计信息"
    },
    {
      "task_id": "task_calibrate",
      "name": "率定GR4J模型",
      "description": "使用SCE-UA算法对GR4J水文模型进行参数率定",
      "tool_name": "calibrate_model",
      "type": "simple",
      "parameters": {
        "data_type": "owndata",
        "data_dir": "D:\\MCP\\HydroAgent\\data\\camels_11532500",
        "result_dir": "D:\\MCP\\HydroAgent\\result",
        "exp_name": "complete_workflow_exp",
        "cv_fold": 1,
        "warmup": 720,
        "periods": ["2000-01-01", "2023-12-31"],
        "train_period": ["2000-01-01", "2018-12-31"],
        "test_period": ["2019-01-01", "2023-12-31"],
        "basin_ids": ["11532500"],
        "model": {
          "name": "gr4j",
          "source_type": "sources",
          "source_book": "HF",
          "kernel_size": 15,
          "time_interval_hours": 24
