{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HydroModel Configuration Schema",
  "description": "Schema definition for hydromodel configuration files based on example_config.yaml",
  "type": "object",
  "required": [
    "model_name",
    "basin_id",
    "train_period"
  ],
  "properties": {
    "exp_name": {
      "type": "string",
      "description": "Experiment name identifier"
    },
    "model_name": {
      "type": "string",
      "enum": [
        "xaj",
        "xaj_mz",
        "gr4j",
        "gr5j",
        "gr6j",
        "gr1y",
        "gr2m"
      ],
      "description": "Hydrological model name"
    },
    "basin_id": {
      "type": "string",
      "description": "Basin identifier (e.g., '01013500', 'camels_01013500')"
    },
    "data": {
      "type": "object",
      "properties": {
        "datasets-origin": {
          "type": "string",
          "description": "Path to dataset directory"
        },
        "warmup": {
          "type": "integer",
          "minimum": 0,
          "description": "Warmup period in days"
        }
      }
    },
    "training_cfgs": {
      "type": "object",
      "description": "Training/calibration configuration",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "SCE_UA",
            "GA",
            "scipy"
          ],
          "description": "Optimization algorithm"
        },
        "ngs": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of complexes (SCE-UA)"
        },
        "npg": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of points in each complex (SCE-UA)"
        },
        "npt": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of points in each sub-complex (SCE-UA)"
        },
        "rep": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of evolution steps (SCE-UA)"
        },
        "maxn": {
          "type": "integer",
          "minimum": 100,
          "description": "Maximum number of function evaluations"
        },
        "pop_size": {
          "type": "integer",
          "minimum": 10,
          "description": "Population size (GA)"
        },
        "max_generations": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum generations (GA)"
        }
      }
    },
    "train_period": {
      "type": "array",
      "description": "Training time period [start_date, end_date]",
      "items": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "test_period": {
      "type": "array",
      "description": "Testing time period [start_date, end_date]",
      "items": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "warmup": {
      "type": "integer",
      "minimum": 0,
      "description": "Warmup period in days (deprecated, use data.warmup instead)"
    }
  },
  "additionalProperties": true
}
